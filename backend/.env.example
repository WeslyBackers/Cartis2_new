# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# For local PostgreSQL:
DATABASE_URL=postgresql://postgres:password@localhost:5432/cartis
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cartis
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# For Supabase - Direct connection (recommended for migrations/imports):
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-supabase-password
# DB_SSL=true

# For Supabase - Session pooler (recommended for runtime apps):
# DB_HOST=aws-0-your-region.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.your-project-ref
# DB_PASSWORD=your-supabase-password
# DB_SSL=true

# Optional: single-URL format instead of DB_HOST/DB_PORT/DB_* variables
# DATABASE_URL=postgresql://postgres:your-supabase-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Optional Supabase API Keys (for direct Supabase client usage):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Email Configuration (voor nautinfo mailbox)
MAIL_HOST=smtp.vlaanderen.be
MAIL_PORT=587
MAIL_USER=nautinfo@mow.vlaanderen.be
MAIL_PASSWORD=
MAIL_FROM=nautinfo@mow.vlaanderen.be

# External APIs
MRCC_API_URL=https://api.mrcc.be
BASS_API_URL=https://api.vts-scheldt.be
POAB_API_URL=https://api.portofantwerp.be
FLARIS_API_URL=https://euris.api.vlaanderen.be

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CARIS Integration
CARIS_API_URL=http://localhost:8080/caris
CARIS_HPD_PATH=C:/CARIS/HPD
